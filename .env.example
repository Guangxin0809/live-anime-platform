# PostgreSQL
DB_USER=anime
DB_PASSWORD=anime_secret
DB_NAME=anime_platform

# Next.js
APP_PORT=3000
NODE_ENV=development
BUILD_TARGET=development

# Prisma (Docker: use @db:5432, local: use @localhost:5432)
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}

# JWT
JWT_SECRET=your-jwt-secret-here

# Alipay
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# WeChat Pay
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
